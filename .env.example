# ── Backend ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_PORT=80

# URL del backend que nginx (dentro del contenedor frontend) usa para proxear /api
#   Docker Compose local → http://backend:8000   (nombre del servicio en la red interna)
#   Railway              → http://<nombre-servicio>.railway.internal:<PORT>
BACKEND_URL=http://backend:8000
